PROJECT_NAME           = "ndarray"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs/doxygen"
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = "@CMAKE_SOURCE_DIR@"

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO
QT_AUTOBRIEF           = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

INPUT                  = "@CMAKE_SOURCE_DIR@/inc/container/ndarray.hpp" \
                         "@CMAKE_SOURCE_DIR@/src/container/ndarray_typed.cpp" \
                         "@CMAKE_SOURCE_DIR@/tests/ndarray/ndarray_typed.cpp" \
                         "@CMAKE_SOURCE_DIR@/tests/ndarray/ndarray_arithmetic.cpp" \
                         "@CMAKE_SOURCE_DIR@/doc/algo-export-aot-compile.md" \
                         "@CMAKE_SOURCE_DIR@/doc/custom-kernel-torch-aot.md"
FILE_PATTERNS          = *.hpp \
                         *.cpp \
                         *.md
RECURSIVE              = NO
EXCLUDE_SYMLINKS       = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
